  },
  "bugs": {
    "url": "https://github.com/damonzwicker/verafile/issues"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
